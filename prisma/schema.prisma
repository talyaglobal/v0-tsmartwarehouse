generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model migrations {
  id         Int       @id @default(dbgenerated("nextval('_migrations_id_seq'::regclass)"))
  name       String    @unique
  applied_at DateTime? @default(now()) @db.Timestamptz(6)

  @@map("_migrations")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model access_logs {
  id                                              String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  visitor_type                                    String
  warehouse_id                                    String     @db.Uuid
  entry_time                                      DateTime   @default(now()) @db.Timestamptz(6)
  exit_time                                       DateTime?  @db.Timestamptz(6)
  status                                          String     @default("checked_in")
  person_name                                     String
  person_id_number                                String?
  person_phone                                    String?
  person_email                                    String?
  company_name                                    String?
  person_id                                       String?    @db.Uuid
  vehicle_license_plate                           String?
  vehicle_make                                    String?
  vehicle_model                                   String?
  vehicle_color                                   String?
  vehicle_type                                    String?
  purpose                                         String?
  authorized_by                                   String?
  authorized_by_id                                String?    @db.Uuid
  booking_id                                      String?    @db.Uuid
  notes                                           String?
  photo_url                                       String?
  checked_in_by                                   String?    @db.Uuid
  checked_out_by                                  String?    @db.Uuid
  created_at                                      DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                                      DateTime?  @default(now()) @db.Timestamptz(6)
  profiles_access_logs_authorized_by_idToprofiles profiles?  @relation("access_logs_authorized_by_idToprofiles", fields: [authorized_by_id], references: [id], onUpdate: NoAction)
  bookings                                        bookings?  @relation(fields: [booking_id], references: [id], onUpdate: NoAction)
  profiles_access_logs_checked_in_byToprofiles    profiles?  @relation("access_logs_checked_in_byToprofiles", fields: [checked_in_by], references: [id], onUpdate: NoAction)
  profiles_access_logs_checked_out_byToprofiles   profiles?  @relation("access_logs_checked_out_byToprofiles", fields: [checked_out_by], references: [id], onUpdate: NoAction)
  profiles_access_logs_person_idToprofiles        profiles?  @relation("access_logs_person_idToprofiles", fields: [person_id], references: [id], onUpdate: NoAction)
  warehouses                                      warehouses @relation(fields: [warehouse_id], references: [id], onUpdate: NoAction)

  @@index([booking_id], map: "idx_access_logs_booking_id")
  @@index([entry_time(sort: Desc)], map: "idx_access_logs_entry_time")
  @@index([person_id], map: "idx_access_logs_person_id")
  @@index([person_id_number], map: "idx_access_logs_person_id_number")
  @@index([person_name], map: "idx_access_logs_person_name")
  @@index([status], map: "idx_access_logs_status")
  @@index([visitor_type, warehouse_id, status, entry_time(sort: Desc)], map: "idx_access_logs_type_warehouse_status")
  @@index([vehicle_license_plate], map: "idx_access_logs_vehicle_license_plate")
  @@index([visitor_type], map: "idx_access_logs_visitor_type")
  @@index([warehouse_id, entry_time(sort: Desc)], map: "idx_access_logs_warehouse_date")
  @@index([warehouse_id], map: "idx_access_logs_warehouse_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appointment_participants {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  appointment_id String       @db.Uuid
  user_id        String       @db.Uuid
  role           String       @default("attendee")
  status         String       @default("pending")
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  appointments   appointments @relation(fields: [appointment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles       profiles     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([appointment_id, user_id])
  @@index([appointment_id], map: "idx_appointment_participants_appointment_id")
  @@index([status], map: "idx_appointment_participants_status")
  @@index([user_id], map: "idx_appointment_participants_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appointment_types {
  id                       String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                     String
  slug                     String         @unique
  description              String?
  color                    String         @default("#3b82f6")
  icon                     String?
  duration_minutes         Int            @default(60)
  requires_warehouse_staff Boolean?       @default(false)
  is_active                Boolean?       @default(true)
  created_by               String         @db.Uuid
  created_at               DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?      @default(now()) @db.Timestamptz(6)
  profiles                 profiles       @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  appointments             appointments[]

  @@index([created_by], map: "idx_appointment_types_created_by")
  @@index([is_active], map: "idx_appointment_types_is_active")
  @@index([slug], map: "idx_appointment_types_slug")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appointments {
  id                       String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  warehouse_id             String                     @db.Uuid
  appointment_type_id      String                     @db.Uuid
  title                    String
  description              String?
  start_time               DateTime                   @db.Timestamptz(6)
  end_time                 DateTime                   @db.Timestamptz(6)
  status                   String                     @default("pending")
  created_by               String                     @db.Uuid
  location                 String?
  meeting_link             String?
  phone_number             String?
  notes                    String?
  created_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  appointment_participants appointment_participants[]
  appointment_types        appointment_types          @relation(fields: [appointment_type_id], references: [id], onUpdate: NoAction)
  profiles                 profiles                   @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  warehouses               warehouses                 @relation(fields: [warehouse_id], references: [id], onUpdate: NoAction)

  @@index([appointment_type_id], map: "idx_appointments_appointment_type_id")
  @@index([created_by], map: "idx_appointments_created_by")
  @@index([start_time, end_time], map: "idx_appointments_date_range")
  @@index([start_time], map: "idx_appointments_start_time")
  @@index([status], map: "idx_appointments_status")
  @@index([warehouse_id], map: "idx_appointments_warehouse_id")
}

