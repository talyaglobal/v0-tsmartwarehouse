model bookings {
  id                                                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                                               String                     @db.Uuid
  customer_name                                             String
  customer_email                                            String
  warehouse_id                                              String                     @db.Uuid
  type                                                      String
  status                                                    String
  pallet_count                                              Int?
  area_sq_ft                                                Int?
  floor_number                                              Int?
  hall_id                                                   String?                    @db.Uuid
  start_date                                                DateTime                   @db.Date
  end_date                                                  DateTime?                  @db.Date
  total_amount                                              Decimal                    @db.Decimal(10, 2)
  notes                                                     String?
  created_at                                                DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at                                                DateTime?                  @default(now()) @db.Timestamptz(6)
  metadata                                                  Json?                      @default("{}")
  proposal_id                                               String?                    @db.Uuid
  approved_by                                               String?                    @db.Uuid
  approved_at                                               DateTime?                  @db.Timestamptz(6)
  payment_status                                            String?                    @default("pending")
  payment_intent_id                                         String?
  payment_method_id                                         String?
  guest_email                                               String?
  is_guest_booking                                          Boolean?                   @default(false)
  stripe_customer_id                                        String?
  amount_paid                                               Decimal?                   @default(0) @db.Decimal(10, 2)
  amount_due                                                Decimal?                   @db.Decimal(10, 2)
  paid_at                                                   DateTime?                  @db.Timestamptz(6)
  payment_notes                                             String?
  booking_status                                            String?                    @default("pending")
  cancel_requested_by                                       String?                    @db.Uuid
  cancel_requested_at                                       DateTime?                  @db.Timestamptz(6)
  cancellation_reason                                       String?
  refund_amount                                             Decimal?                   @db.Decimal(10, 2)
  refund_status                                             String?
  deposit_amount                                            Decimal?                   @db.Decimal(10, 2)
  deposit_status                                            String?                    @default("none")
  deposit_paid_at                                           DateTime?                  @db.Timestamptz(6)
  booked_by                                                 String?                    @db.Uuid
  booked_on_behalf_of                                       String?                    @db.Uuid
  requires_approval                                         Boolean?                   @default(false)
  approval_status                                           String?
  short_id                                                  String?
  created_by                                                String?                    @db.Uuid
  updated_by                                                String?                    @db.Uuid
  access_logs                                               access_logs[]
  booking_approvals                                         booking_approvals[]
  booking_modifications                                     booking_modifications[]
  booking_proposals_booking_proposals_booking_idTobookings  booking_proposals[]        @relation("booking_proposals_booking_idTobookings")
  booking_requests                                          booking_requests[]
  booking_services                                          booking_services[]
  booking_usage_periods                                     booking_usage_periods[]
  profiles_bookings_approved_byToprofiles                   profiles?                  @relation("bookings_approved_byToprofiles", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles_bookings_customer_idToprofiles                   profiles                   @relation("bookings_customer_idToprofiles", fields: [customer_id], references: [id], onUpdate: NoAction)
  warehouse_halls                                           warehouse_halls?           @relation(fields: [hall_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  booking_proposals_bookings_proposal_idTobooking_proposals booking_proposals?         @relation("bookings_proposal_idTobooking_proposals", fields: [proposal_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses                                                warehouses                 @relation(fields: [warehouse_id], references: [id], onUpdate: NoAction)
  claims                                                    claims[]
  estimates                                                 estimates[]
  incidents                                                 incidents[]
  inventory_items                                           inventory_items[]
  invoices                                                  invoices[]
  pallet_checkout_requests                                  pallet_checkout_requests[]
  service_orders                                            service_orders[]
  shipments                                                 shipments[]
  tasks                                                     tasks[]
  warehouse_messages                                        warehouse_messages[]
  warehouse_reviews                                         warehouse_reviews[]

  @@index([approved_by], map: "idx_bookings_approved_by")
  @@index([customer_id], map: "idx_bookings_customer_id")
  @@index([metadata], map: "idx_bookings_metadata", type: Gin)
  @@index([proposal_id], map: "idx_bookings_proposal_id")
  @@index([start_date], map: "idx_bookings_start_date")
  @@index([status], map: "idx_bookings_status")
  @@index([type], map: "idx_bookings_type")
  @@index([warehouse_id], map: "idx_bookings_warehouse_id")
}

model broker_customers {
  broker_id   String    @db.Uuid
  customer_id String    @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  brokers     brokers   @relation(fields: [broker_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles    profiles  @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([broker_id, customer_id])
  @@index([broker_id], map: "idx_broker_customers_broker_id")
  @@index([customer_id], map: "idx_broker_customers_customer_id")
}

model brokers {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String
  email            String?            @unique
  company          String?
  phone            String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  broker_customers broker_customers[]

  @@index([email], map: "idx_brokers_email")
  @@index([name], map: "idx_brokers_name")
}

